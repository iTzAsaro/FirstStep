{
  "name": "firststep-scripts",
  "private": true,
  "version": "0.1.0",
  "description": "Scripts utilitarios para FirstStep (seed, migraciones, etc.)",
  "scripts": {
    "seed":       "ts-node seed.ts",
    "seed:clean": "ts-node seed.ts --clean"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "postgres":  "^3.4.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node":     "^20.0.0",
    "ts-node":         "^10.9.2",
    "typescript":      "^5.4.0"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "esModuleInterop": true
    }
  },
  "type": "commonjs"
}
